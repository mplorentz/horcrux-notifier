HORCRUX_NOTIFIER_BIND=0.0.0.0:8080
HORCRUX_NOTIFIER_DATABASE_URL=sqlite://data/horcrux_notifier.db?mode=rwc

# Absolute path to the Google service-account JSON for the Firebase project.
# The account must have the "Firebase Cloud Messaging API Admin" role.
HORCRUX_NOTIFIER_FCM_SERVICE_ACCOUNT=/etc/horcrux_notifier/fcm-service-account.json

# How many seconds of drift to tolerate on NIP-98 created_at timestamps.
HORCRUX_NOTIFIER_NIP98_MAX_AGE_SECS=60

# Rate limits.
HORCRUX_NOTIFIER_PUSH_PAIR_WINDOW_SECS=30
HORCRUX_NOTIFIER_PUSH_PAIR_MAX=1
HORCRUX_NOTIFIER_PUSH_RECIPIENT_WINDOW_SECS=3600
HORCRUX_NOTIFIER_PUSH_RECIPIENT_MAX=60

# Logging
RUST_LOG=horcrux_notifier=info,tower_http=info
